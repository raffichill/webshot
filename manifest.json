{
  "manifest_version": 3,
  "name": "Webshot",
  "version": "1.0.0",
  "description": "Right-click any page to copy a screenshot to the clipboard for moodboarding.",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Webshot — capture this tab"
  }
}
